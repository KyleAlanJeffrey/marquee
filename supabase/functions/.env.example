# Edge function secrets.
# Local dev: copy to supabase/functions/.env (picked up by `supabase functions serve`).
# Hosted: `supabase secrets set --env-file supabase/functions/.env`

# Spotify app (https://developer.spotify.com/dashboard) — used by search-artists
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Ticketmaster Discovery API key (https://developer.ticketmaster.com) — used by ingest-events
TICKETMASTER_API_KEY=

# Bandsintown app id (https://artists.bandsintown.com/support/public-api) — optional
BANDSINTOWN_APP_ID=

# Shared secret between pg_cron and ingest-events; any long random string
CRON_SECRET=

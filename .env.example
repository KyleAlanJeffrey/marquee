# Copy to .env and set the Marquee Worker API URL.
# Local dev:  http://localhost:8787  (from `wrangler dev` in ./worker)
# Deployed:   https://marquee-worker.<your-subdomain>.workers.dev
EXPO_PUBLIC_API_URL=http://localhost:8787

# Optional: a Mapbox *public* token (pk.*) turns the "Nearby Venues" card into a
# real dark map (Mapbox Static Images API). Without it, a stylized grid is shown.
# Publishable client-side; set it here for local dev and as a build-time env var
# in Cloudflare Workers Builds for production.
# EXPO_PUBLIC_MAPBOX_TOKEN=pk.xxxxx
